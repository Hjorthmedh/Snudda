    "cnc.define_striatum(num_dSPN=5, num_iSPN=5, num_FS=5, num_LTS=0, num_ChIN=0,\n",
    "                    volume_type=\"cube\", side_len=100e-6)\n",
    "cnc.write_json()"
   ]
